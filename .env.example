# ── InvestIQ provider keys ─────────────────────────────────────────────
# Set at least ONE of these. The LLM router tries providers in priority
# order (Gemini → Groq → Cerebras → OpenRouter → SwiftRouter) and
# automatically rotates to the next on error or rate limit.

GEMINI_API_KEY=            # aistudio.google.com — gemini-2.5-flash
GROQ_API_KEY=              # console.groq.com — llama-3.3-70b, gpt-oss-120b
CEREBRAS_API_KEY=          # cloud.cerebras.ai — gpt-oss-120b, zai-glm-4.7
OPENROUTER_API_KEY_1=      # openrouter.ai — :free models
OPENROUTER_API_KEY_2=      # optional second OpenRouter key for extra quota
SWIFTROUTER_API_KEY=       # swiftrouter.com

# Optional: live web search grounding for the research phase
TAVILY_API_KEY=            # tavily.com — free tier available
